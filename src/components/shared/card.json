{
    "collectionName": "components_shared_cards",
    "info": {
        "displayName": "Card",
        "description": "Shared content card with image, title and description"
    },
    "options": {},
    "attributes": {
        "displayType": {
            "type": "enumeration",
            "enum": [
                "static",
                "withBackground",
                "withPicture"
            ],
            "default": "withPicture",
            "required": true
        },
        "image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "title": {
            "type": "string",
            "required": true
        },
        "description": {
            "type": "text"
        }
    }
}